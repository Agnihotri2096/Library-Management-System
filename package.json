{
  "name": "library-management-system",
  "version": "1.0.0",
  "description": "College Library Management System with Student & Librarian portals",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "postinstall": "cd client && npm install"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
