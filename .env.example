# ── Backend (Render) ─────────────────────────────────────
PORT=3000
NODE_ENV=development

# REQUIRED in production — set in Render dashboard
JWT_SECRET=change_me_to_a_long_random_string

# Your Vercel frontend URL (set in Render dashboard)
CLIENT_URL=https://ghec-library.vercel.app

# Optional — SQLite file location (auto-set on Render via /data mount)
# DB_PATH=/data/library.db

# Optional — Nodemailer for overdue email alerts
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Frontend (Vercel) ─────────────────────────────────────
# Create client/.env.local for local dev, set in Vercel dashboard for production
# VITE_API_URL=https://your-render-service.onrender.com
